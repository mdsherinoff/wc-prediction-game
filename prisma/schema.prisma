// Prisma schema for the World Cup 2026 Predictor

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  groupPredictions    GroupPrediction[]
  knockoutPredictions KnockoutPrediction[]
  bracketPicks        BracketPick[]
  manualAdjustment    ManualAdjustment?
  awardPicks          AwardPick[]

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

model Team {
  id          String  @id @default(cuid())
  name        String  @unique
  fifaCode    String? @unique
  flagUrl     String?
  groupName   String?
  fifaRanking Int?    // manually entered, refreshed occasionally by admin

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

// A single match, group or knockout.
// externalId links to the football-data.org fixture id for automated result sync.
model Match {
  id         String  @id @default(cuid())
  externalId String? @unique
  stage      Stage
  groupName  String?
  slotKey    String? @unique

  homeTeamId String?
  awayTeamId String?
  homeTeam   Team?   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  kickoff DateTime
  status  MatchStatus @default(SCHEDULED)

  homeScore    Int?
  awayScore    Int?
  wentToPens   Boolean @default(false)
  penHomeScore Int?
  penAwayScore Int?

  winnerTeamId String?

  groupPredictions    GroupPrediction[]
  knockoutPredictions KnockoutPrediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([kickoff])
}

model GroupPrediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  homeScore Int?
  awayScore Int?

  // True if this was backfilled as "known to be a wrong guess" without
  // recording the actual scoreline they guessed
  knownIncorrect Boolean @default(false)

  pointsAwarded Int?     // filled in once match finishes & is scored; null until then
  scoredAt      DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
}

model KnockoutPrediction {
  id              String  @id @default(cuid())
  userId          String
  matchId         String
  predictedWinner String? // Team id; null if we only know they got it wrong, not who they picked
  homeScore       Int?    // optional exact-score guess (regulation/ET, not pens)
  awayScore       Int?

  knownIncorrect Boolean @default(false)

  pointsAwarded Int?
  scoredAt      DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
}

model BracketPick {
  id      String @id @default(cuid())
  userId  String
  stage   Stage // R32, R16, QF, SF, FINAL, THIRD_PLACE (the round being predicted)
  slotKey String // matches Match.slotKey this pick is about
  teamId  String // the team this user predicts will win that slot

  pointsAwarded Int?
  scoredAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slotKey])
  @@index([stage])
  @@index([slotKey])
}

// Simple global setting flags, e.g. whether knockout bracket stage has unlocked.
model Setting {
  key   String @id
  value String
}

model ManualAdjustment {
  id     String  @id @default(cuid())
  userId String  @unique
  points Int
  note   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Player {
  id        String  @id @default(cuid())
  name      String
  country   String  // matches team_country from the CSV, ideally also matching Team.name
  position  String? // raw code from CSV: "FW", "MF", "DF", "GK"
  club      String?
  ageLabel  String? // raw "27-010" style string from CSV, display-only
  birthYear Int?    // used to enforce the Young Player award's Jan 1 2005 cutoff

  awardPicks   AwardPick[]
  awardWinners AwardWinner[]

  @@unique([name, country])
  @@index([country])
  @@index([position])
}

enum AwardCategory {
  GOLDEN_BALL
  GOLDEN_BOOT
  GOLDEN_GLOVE
  YOUNG_PLAYER
}

model AwardPick {
  id       String        @id @default(cuid())
  userId   String
  category AwardCategory
  playerId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  pointsAwarded Int?
  scoredAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
  @@index([category])
}

// The actual real-world winner of each award, set by admin once announced.
model AwardWinner {
  category  AwardCategory @id
  playerId  String
  player    Player        @relation(fields: [playerId], references: [id])
  decidedAt DateTime      @default(now())
}

model PointsConfig {
  key   String @id // e.g. "GROUP_EXACT", "KNOCKOUT_WINNER", "KNOCKOUT_EXACT_BONUS", "BRACKET_ADVANCER", "AWARD_PICK"
  value Int
  label String // human-readable label for the admin UI
  group String // "GROUP" | "KNOCKOUT" | "BRACKET" | "AWARDS" — for organizing the dashboard

  updatedAt DateTime @updatedAt
}